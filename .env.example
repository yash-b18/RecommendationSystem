# ============================================================
# Environment variables — copy to .env and fill in values
# ============================================================

# HuggingFace token (only needed if dataset requires authentication)
HF_TOKEN=

# API server settings (optional overrides for src/config.py)
API_HOST=0.0.0.0
API_PORT=8000

# Frontend environment (set in frontend/.env.local)
NEXT_PUBLIC_API_URL=http://localhost:8000
